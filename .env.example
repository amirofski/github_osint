# GitHub OSINT Intelligence Tool - Configuration Example
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (Required)
# Get one from: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Output Format: json or csv (Default: json)
OUTPUT_FORMAT=json

# Default Output File (Optional)
# If not set, files are auto-generated with timestamp
OUTPUT_FILE=results.json

# Optional: Logging Level (Default: INFO)
# LOG_LEVEL=INFO

# Optional: GitHub API Base URL (Default: https://api.github.com)
# GITHUB_API_BASE=https://api.github.com
